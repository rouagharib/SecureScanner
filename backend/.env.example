# ── Docker Compose Environment ────────────────────────────────
# Copy this file to .env and update values

# MongoDB
MONGODB_URL=your_mongodb_connection_string_here
DB_NAME=securescan

# JWT
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
MAIL_EMAIL=your_email_here
MAIL_PASSWORD=your_email_password_here

# Application
APP_URL=http://localhost:5173

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
STRIPE_PORTAL_RETURN_URL=http://localhost:5173/billing
STRIPE_STANDARD_MONTHLY_PRICE_ID=your_price_id_here
STRIPE_STANDARD_YEARLY_PRICE_ID=your_price_id_here
STRIPE_PREMIUM_MONTHLY_PRICE_ID=your_price_id_here
STRIPE_PREMIUM_YEARLY_PRICE_ID=your_price_id_here
TRIAL_DAYS=14
SUBSCRIPTION_GRACE_DAYS=3